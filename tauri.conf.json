{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "CareDoc",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://**", "http://localhost/**", "http://127.0.0.1/**"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.caredoc.app",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
    },
    "security": { "csp": null },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "CareDoc",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "plugins": {
      "sql": {
        "preload": ["sqlite:caredoc.db"]
      }
    }
  }
}
